# IB Gateway connection
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=1

# Trading mode: paper | live
TRADING_MODE=paper

# IB Gateway credentials (for Docker auto-login)
TWS_USERID=
TWS_PASSWORD=

# Portfolio allocation targets (percentages, must sum to 100)
ALLOC_VTI=42
ALLOC_VXUS=28
ALLOC_BND=18
ALLOC_BNDX=12

# Rebalance settings
REBALANCE_DRIFT_THRESHOLD=5
REBALANCE_MIN_TRADE_USD=50

# Status server
PORT=3001

# Logging
LOG_LEVEL=info
