{
  "name": "ibkr-fund",
  "version": "0.2.0",
  "description": "Enterprise IBKR fund with multi-agent portfolio management",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "agent:ceo": "node dist/agents/managing-partner.js --once",
    "agent:strategist": "node dist/agents/portfolio-strategist.js --once",
    "agent:quant": "node dist/agents/quant-analyst.js --once",
    "agent:tax": "node dist/agents/tax-optimizer.js --once",
    "agent:risk": "node dist/agents/risk-manager.js --once",
    "agent:hedger": "node dist/agents/hedger.js --once",
    "agent:exec": "node dist/agents/execution-bot.js --once",
    "agent:scout": "node dist/agents/research-scout.js --once",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stoqey/ib": "^1.5.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
